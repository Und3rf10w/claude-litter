/* Dark theme for claude-litter */

Screen {
    background: $surface;
}

/* Main layout */
#main-content {
    width: 1fr;
}

/* Slide-out panels */
.slide-panel {
    offset-x: 100%;
    transition: offset 300ms;
    width: 35%;
    dock: right;
}

.slide-panel.-visible {
    offset-x: 0;
}

/* Header / footer */
Header {
    background: $primary;
    color: $text;
}

Footer {
    background: $panel;
    color: $text-muted;
}

/* Generic label styles */
Label {
    padding: 0 1;
}

/* Input styling */
Input {
    background: $surface;
    border: solid $primary;
}

Input:focus {
    border: solid $accent;
}

/* TextArea (PromptTextArea) styling */
TextArea {
    background: $surface;
    border: solid $primary;
}

TextArea:focus {
    border: solid $accent;
}

/* Button styling */
Button {
    margin: 0 1;
}

/* ListView */
ListView {
    background: $surface;
}

ListItem {
    padding: 0 1;
}

ListItem:hover {
    background: $boost;
}

/* Overlay panels */
.overlay-panel {
    background: $panel;
    border: solid $primary;
}
